BLACKLISTED_PLAYERS=
SCORING_DIAGNOSTICS=false

# ── Optimizer Weights (all optional — defaults are the in-code values shown) ──
# Names ending in "Benefit" ADD to the score, names ending in "Penalty" SUBTRACT.
# Set to override the tuned default.

# WEIGHT_CARD_RATING_BENEFIT=0.25
# WEIGHT_HISTORICAL_TOP20_RATING_BENEFIT=3
# WEIGHT_TOP_TEAM_RANK_BENEFIT=0.5
# WEIGHT_AWPER_ROLE_BENEFIT=0
# WEIGHT_LOW_DEATH_RATE_BENEFIT=0
# WEIGHT_CT_VS_T_RATING_IMBALANCE_PENALTY=0.5
# WEIGHT_STACK_CORRELATION_BENEFIT=0.5
# WEIGHT_TOP_RANKED_TEAM_STACK_BENEFIT=0.25

# ── v5 weights: continuous signals (added 2026) ──
# Continuous AWP/round signal — replaces the binary awperRoleBenefit threshold.
# Default 0 = off (backward-compatible with v4).
# WEIGHT_AWP_PER_ROUND_WEIGHT=0
# Continuous deaths/round penalty — replaces the binary lowDeathRateBenefit threshold.
# WEIGHT_DEATH_PENALTY_WEIGHT=0
# Rating-per-price efficiency — boosts underrated cheap cards.
# WEIGHT_PRICE_EFFICIENCY_BENEFIT=0

# ── Optimizer Thresholds (trigger values for the gated benefits) ──
# A player earns WEIGHT_AWPER_ROLE_BENEFIT if their AWP/round ≥ this value.
# A player earns WEIGHT_LOW_DEATH_RATE_BENEFIT if their deaths/round ≤ this value.

# THRESHOLD_AWPER_ROLE_MIN_AWP_PER_ROUND=0.25
# THRESHOLD_LOW_DEATH_RATE_MAX_DEATHS_PER_ROUND=0.6
